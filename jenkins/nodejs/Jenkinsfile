// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- Node.js
// Stages: Install -> Lint -> Test -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Node.js Alpine image provides npm and a minimal runtime. No volume
    // mount needed; NPM_CONFIG_CACHE in environment caches packages in workspace.
    agent {
        docker {
            image 'node:18-alpine'
        }
    }

    // NPM_CONFIG_CACHE speeds up npm ci by caching packages in workspace.
    environment {
        DOCKER_IMAGE = 'myregistry/nodejs-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
        NPM_CONFIG_CACHE = "${WORKSPACE}/.npm"
    }

    // Pipeline-wide options: 20 min timeout, no concurrent builds, keep last 10.
    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // npm ci installs exact versions from package-lock.json for
        // reproducible builds. Faster and more reliable than npm install.
        stage('Install') {
            steps {
                echo '📦 Installing dependencies...'
                sh 'npm ci'
            }
        }

        // ESLint checks code style and catches common bugs. Requires
        // "lint" script in package.json (e.g., eslint .).
        stage('Lint') {
            steps {
                echo '🔍 Running ESLint...'
                sh 'npm run lint'
            }
        }

        // Run tests with coverage. --coverage enables coverage collection,
        // --ci disables watch mode and uses CI-friendly reporters.
        stage('Test') {
            steps {
                echo '🧪 Running tests with coverage...'
                sh 'npm test -- --coverage --ci'
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'coverage/lcov-report',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                }
            }
        }

        // Build Docker image from project Dockerfile, push to registry.
        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # kubectl set image deployment/nodejs-app nodejs-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
