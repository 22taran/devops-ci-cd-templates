// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- Java (Maven)
// Stages: Build -> Lint -> Test -> Package -> Docker Build -> Docker Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Use a Maven Docker image as the build agent for a reproducible,
    // pre-configured Java build environment. The .m2 volume mount caches
    // downloaded dependencies across builds to speed up subsequent runs.
    agent {
        docker {
            image 'maven:3.9-eclipse-temurin-17'
            args '-v $HOME/.m2:/root/.m2'
        }
    }

    // Environment variables available to all stages. Customize DOCKER_IMAGE
    // for your registry (e.g., ghcr.io/org/repo). DOCKER_TAG uses build
    // number for traceability. DEPLOY_ENV targets staging by default.
    environment {
        DOCKER_IMAGE = 'myregistry/java-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
    }

    // Pipeline-wide options: 30 min timeout prevents runaway builds,
    // disableConcurrentBuilds avoids conflicts, logRotator keeps last 10.
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Compile source code without packaging. -B runs in batch mode
        // (non-interactive). clean removes previous build artifacts.
        stage('Build') {
            steps {
                echo '🔨 Building Java application...'
                sh 'mvn clean compile -B'
            }
        }

        // Run Checkstyle to enforce code style and catch common issues.
        // Fails the build if violations are found.
        stage('Lint') {
            steps {
                echo '🔍 Running code analysis...'
                sh 'mvn checkstyle:check -B'
            }
        }

        // Execute unit tests. post.always publishes JUnit XML for Jenkins
        // test trend charts and JaCoCo exec for coverage reporting.
        stage('Test') {
            steps {
                echo '🧪 Running unit tests...'
                sh 'mvn test -B'
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                    jacoco(execPattern: '**/target/jacoco.exec')
                }
            }
        }

        // Create deployable JAR. -DskipTests avoids re-running tests.
        // archiveArtifacts stores the JAR for download or downstream jobs.
        stage('Package') {
            steps {
                echo '📦 Packaging application...'
                sh 'mvn package -DskipTests -B'
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }

        // Build Docker image from project Dockerfile. Image stays in local
        // daemon for the Push stage (same agent = same node).
        stage('Docker Build') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                }
            }
        }

        // Push image to registry. Requires image from Docker Build stage.
        stage('Docker Push') {
            steps {
                echo '🐳 Pushing Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.image("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy runs on every branch. Replace with your deployment command.
        // Docker: docker run -d -p 8080:8080 ${DOCKER_IMAGE}:${DOCKER_TAG}
        // Kubernetes: kubectl set image deployment/java-app java-app=${DOCKER_IMAGE}:${DOCKER_TAG}
        stage('Deploy') {
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # Docker: docker run -d -p 8080:8080 ${DOCKER_IMAGE}:${DOCKER_TAG}
                    # docker-compose up -d
                    # Kubernetes: kubectl set image deployment/java-app java-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                    # helm upgrade --install java-app ./chart --set image.tag=${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build actions: notify on success/failure, always clean workspace
    // to free disk space and avoid leaking artifacts between builds.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
