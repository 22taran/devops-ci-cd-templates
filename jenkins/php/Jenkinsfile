// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- PHP
// Stages: Install -> Lint -> Test -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // PHP CLI image. COMPOSER_HOME in workspace caches Composer data.
    agent {
        docker {
            image 'php:8.2-cli'
        }
    }

    // COMPOSER_HOME caches Composer packages and config in workspace.
    environment {
        DOCKER_IMAGE    = 'myregistry/php-app'
        DOCKER_TAG      = "${env.BUILD_NUMBER}"
        DEPLOY_ENV      = 'staging'
        COMPOSER_HOME   = "${WORKSPACE}/.composer"
    }

    // Pipeline-wide options: 20 min timeout, no concurrent builds, keep last 10.
    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Install Composer if needed, then install deps from composer.lock.
        // --no-interaction and --prefer-dist suit CI environments.
        stage('Install') {
            steps {
                echo '📦 Installing Composer dependencies...'
                sh '''
                    curl -sS https://getcomposer.org/installer | php
                    php composer.phar install --no-interaction --prefer-dist
                '''
            }
        }

        // phpcs checks PSR-12 style. phpstan performs static analysis at
        // level 5 (balance of strictness vs. noise).
        stage('Lint') {
            steps {
                echo '🔍 Running PHP_CodeSniffer and PHPStan...'
                sh '''
                    vendor/bin/phpcs src/ --standard=PSR12
                    vendor/bin/phpstan analyse src/ --level=5
                '''
            }
        }

        // PHPUnit runs tests with coverage. coverage.xml (Clover) for
        // Cobertura; coverage/ HTML for publishHTML.
        stage('Test') {
            steps {
                echo '🧪 Running PHPUnit tests...'
                sh 'vendor/bin/phpunit tests/ --coverage-html coverage/ --coverage-clover coverage.xml'
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'coverage',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                    cobertura coberturaReportFile: 'coverage.xml'
                }
            }
        }

        // Build Docker image from project Dockerfile, push to registry.
        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy only on main. Replace with your deployment command.
        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # kubectl set image deployment/php-app php-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
