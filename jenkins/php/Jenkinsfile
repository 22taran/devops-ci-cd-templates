pipeline {
    agent {
        docker {
            image 'php:8.2-cli'
        }
    }

    environment {
        DOCKER_IMAGE    = 'myregistry/php-app'
        DOCKER_TAG      = "${env.BUILD_NUMBER}"
        DEPLOY_ENV      = 'staging'
        COMPOSER_HOME   = "${WORKSPACE}/.composer"
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Install') {
            steps {
                echo '📦 Installing Composer dependencies...'
                sh '''
                    curl -sS https://getcomposer.org/installer | php
                    php composer.phar install --no-interaction --prefer-dist
                '''
            }
        }

        stage('Lint') {
            steps {
                echo '🔍 Running PHP_CodeSniffer and PHPStan...'
                sh '''
                    vendor/bin/phpcs src/ --standard=PSR12
                    vendor/bin/phpstan analyse src/ --level=5
                '''
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running PHPUnit tests...'
                sh 'vendor/bin/phpunit tests/ --coverage-html coverage/ --coverage-clover coverage.xml'
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'coverage',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                    cobertura coberturaReportFile: 'coverage.xml'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    // kubectl set image deployment/php-app php-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
