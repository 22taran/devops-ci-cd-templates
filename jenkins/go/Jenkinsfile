// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- Go
// Stages: Build -> Lint -> Test -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Go Alpine image for minimal, fast builds. GOPATH and CGO_ENABLED
    // ensure a clean, static build suitable for containers.
    agent {
        docker {
            image 'golang:1.21-alpine'
        }
    }

    // GOPATH in workspace avoids polluting host. CGO_ENABLED=0 produces
    // static binaries (no C deps), ideal for scratch/distroless images.
    environment {
        DOCKER_IMAGE = 'myregistry/go-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
        GOPATH       = "${WORKSPACE}/go"
        CGO_ENABLED  = '0'
    }

    // Pipeline-wide options: 20 min timeout, no concurrent builds, keep last 10.
    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Compile all packages. -v verbose, -o bin/app outputs single binary.
        stage('Build') {
            steps {
                echo '🔨 Building Go application...'
                sh 'go build -v -o bin/app ./...'
            }
        }

        // go vet finds suspicious constructs; staticcheck adds stricter
        // static analysis. go install fetches staticcheck on first run.
        stage('Lint') {
            steps {
                echo '🔍 Running go vet and staticcheck...'
                sh '''
                    go vet ./...
                    go install honnef.co/go/tools/cmd/staticcheck@latest
                    staticcheck ./...
                '''
            }
        }

        // Run tests with coverage. -coverprofile writes coverage.out;
        // go tool cover -html generates HTML report for publishHTML.
        stage('Test') {
            steps {
                echo '🧪 Running tests with coverage...'
                sh 'go test -v -coverprofile=coverage.out ./...'
                sh 'go tool cover -html=coverage.out -o coverage.html'
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: '.',
                        reportFiles: 'coverage.html',
                        reportName: 'Coverage Report'
                    ])
                }
            }
        }

        // Build Docker image from project Dockerfile, push to registry.
        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy only on main. Replace with your deployment command.
        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # kubectl set image deployment/go-app go-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
