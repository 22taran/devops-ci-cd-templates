pipeline {
    agent {
        docker {
            image 'python:3.12-slim'
        }
    }

    environment {
        DOCKER_IMAGE = 'myregistry/python-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
        PIP_CACHE_DIR = "${WORKSPACE}/.pip-cache"
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Install') {
            steps {
                echo '📦 Installing dependencies...'
                sh '''
                    python -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Lint') {
            steps {
                echo '🔍 Running flake8...'
                sh '''
                    . venv/bin/activate
                    flake8 app.py --max-line-length=120 --statistics
                '''
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running pytest with coverage...'
                sh '''
                    . venv/bin/activate
                    pytest tests/ -v --cov=. --cov-report=xml --cov-report=html
                '''
            }
            post {
                always {
                    cobertura coberturaReportFile: 'coverage.xml'
                    publishHTML(target: [
                        reportDir: 'htmlcov',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    // kubectl set image deployment/python-app python-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
