// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- Python
// Stages: Install -> Lint -> Test -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Use Python 3.12 slim image for a minimal, reproducible build environment.
    // No volume mounts; PIP_CACHE_DIR in environment caches pip packages.
    agent {
        docker {
            image 'python:3.12-slim'
        }
    }

    // PIP_CACHE_DIR caches pip downloads in workspace to speed up installs.
    environment {
        DOCKER_IMAGE = 'myregistry/python-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
        PIP_CACHE_DIR = "${WORKSPACE}/.pip-cache"
    }

    // Pipeline-wide options: 20 min timeout, no concurrent builds, keep last 10.
    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Create virtual env and install dependencies from requirements.txt.
        // venv isolates project deps; activate before lint and test.
        stage('Install') {
            steps {
                echo '📦 Installing dependencies...'
                sh '''
                    python -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }

        // Run flake8 for style and complexity checks. --max-line-length=120
        // allows slightly longer lines; --statistics shows violation counts.
        stage('Lint') {
            steps {
                echo '🔍 Running flake8...'
                sh '''
                    . venv/bin/activate
                    flake8 app.py --max-line-length=120 --statistics
                '''
            }
        }

        // Run pytest with coverage. --cov=. measures all code; xml and html
        // reports for Jenkins Cobertura plugin and publishHTML.
        stage('Test') {
            steps {
                echo '🧪 Running pytest with coverage...'
                sh '''
                    . venv/bin/activate
                    pytest tests/ -v --cov=. --cov-report=xml --cov-report=html
                '''
            }
            post {
                always {
                    cobertura coberturaReportFile: 'coverage.xml'
                    publishHTML(target: [
                        reportDir: 'htmlcov',
                        reportFiles: 'index.html',
                        reportName: 'Coverage Report'
                    ])
                }
            }
        }

        // Build Docker image from project Dockerfile.
        stage('Docker Build') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                }
            }
        }

        // Push image to registry with build tag and latest.
        stage('Docker Push') {
            steps {
                echo '🐳 Pushing Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.image("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy to staging. Replace with your deployment (kubectl, Helm, docker run, etc.).
        stage('Deploy') {
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # Docker: docker run -d -p 8080:8080 ${DOCKER_IMAGE}:${DOCKER_TAG}
                    # Kubernetes: kubectl set image deployment/python-app python-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
