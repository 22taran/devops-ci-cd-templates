// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- Rust
// Stages: Build -> Lint -> Test -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Rust slim image. CARGO_HOME in workspace caches crates to speed
    // up subsequent builds (rustup, cargo downloads).
    agent {
        docker {
            image 'rust:1.73-slim'
        }
    }

    // CARGO_HOME caches cargo and rustup data in workspace.
    environment {
        DOCKER_IMAGE = 'myregistry/rust-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
        CARGO_HOME   = "${WORKSPACE}/.cargo"
    }

    // Rust builds can be slow; 30 min timeout. No concurrent builds, keep last 10.
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Compile release binary. --release enables optimizations.
        stage('Build') {
            steps {
                echo '🔨 Building Rust application...'
                sh 'cargo build --release'
            }
        }

        // clippy catches common mistakes; rustfmt checks formatting.
        // rustup component add ensures tools are available. -D warnings
        // treats clippy warnings as errors.
        stage('Lint') {
            steps {
                echo '🔍 Running clippy and format check...'
                sh '''
                    rustup component add clippy rustfmt
                    cargo clippy -- -D warnings
                    cargo fmt -- --check
                '''
            }
        }

        // Run unit and integration tests. --verbose shows test names.
        stage('Test') {
            steps {
                echo '🧪 Running tests...'
                sh 'cargo test --verbose'
            }
        }

        // Build Docker image from project Dockerfile, push to registry.
        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy only on main. Replace with your deployment command.
        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # kubectl set image deployment/rust-app rust-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
