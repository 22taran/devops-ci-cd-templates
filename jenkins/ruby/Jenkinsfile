// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- Ruby
// Stages: Install -> Lint -> Test -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Ruby slim image for minimal footprint. BUNDLE_PATH caches gems
    // in workspace to speed up subsequent installs.
    agent {
        docker {
            image 'ruby:3.3-slim'
        }
    }

    // BUNDLE_PATH stores gems in workspace for faster bundle install.
    environment {
        DOCKER_IMAGE = 'myregistry/ruby-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
        BUNDLE_PATH  = "${WORKSPACE}/vendor/bundle"
    }

    // Pipeline-wide options: 20 min timeout, no concurrent builds, keep last 10.
    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Install gems from Gemfile.lock for reproducible builds.
        stage('Install') {
            steps {
                echo '📦 Installing gems...'
                sh 'bundle install'
            }
        }

        // RuboCop enforces Ruby style guide. Fails build on violations.
        stage('Lint') {
            steps {
                echo '🔍 Running RuboCop...'
                sh 'bundle exec rubocop'
            }
        }

        // RSpec runs tests. --format documentation and html produce
        // readable console output and HTML report for publishHTML.
        stage('Test') {
            steps {
                echo '🧪 Running RSpec tests...'
                sh 'bundle exec rspec --format documentation --format html --out rspec_results.html'
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: '.',
                        reportFiles: 'rspec_results.html',
                        reportName: 'RSpec Report'
                    ])
                }
            }
        }

        // Build Docker image from project Dockerfile, push to registry.
        stage('Docker Build & Push') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy only on main. Replace with your deployment command.
        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # kubectl set image deployment/ruby-app ruby-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
