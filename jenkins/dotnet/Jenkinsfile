// ---------------------------------------------------------------------------
// Jenkins Declarative Pipeline -- .NET
// Stages: Restore -> Build -> Lint -> Test -> Publish -> Docker Build & Push -> Deploy
// Requires: Docker Pipeline plugin, docker-hub-credentials, deploy-credentials
// ---------------------------------------------------------------------------

pipeline {
    // Microsoft .NET SDK image for building and testing. Includes runtime
    // and SDK tools (dotnet CLI, MSBuild, test runners).
    agent {
        docker {
            image 'mcr.microsoft.com/dotnet/sdk:8.0'
        }
    }

    environment {
        DOCKER_IMAGE = 'myregistry/dotnet-app'
        DOCKER_TAG   = "${env.BUILD_NUMBER}"
        DEPLOY_ENV   = 'staging'
    }

    // .NET builds can be slower; 30 min timeout. No concurrent builds, keep last 10.
    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // Restore NuGet packages. Separate stage allows caching in some setups.
        stage('Restore') {
            steps {
                echo '📦 Restoring NuGet packages...'
                sh 'dotnet restore'
            }
        }

        // Compile without re-restoring. --no-restore uses packages from Restore stage.
        stage('Build') {
            steps {
                echo '🔨 Building .NET application...'
                sh 'dotnet build --no-restore --configuration Release'
            }
        }

        // dotnet format checks code style. --verify-no-changes fails if
        // formatting would change (enforces consistent style).
        stage('Lint') {
            steps {
                echo '🔍 Running code analysis...'
                sh 'dotnet format --verify-no-changes --verbosity diagnostic'
            }
        }

        // Run tests with code coverage. --no-build uses existing build.
        // XPlat Code Coverage produces Cobertura XML for Jenkins.
        stage('Test') {
            steps {
                echo '🧪 Running tests with coverage...'
                sh 'dotnet test --no-build --configuration Release --collect:"XPlat Code Coverage" --results-directory ./TestResults'
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'TestResults',
                        reportFiles: '*/coverage.cobertura.xml',
                        reportName: 'Coverage Report'
                    ])
                }
            }
        }

        // Publish produces deployable output in ./publish. archiveArtifacts
        // stores it for download or downstream jobs.
        stage('Publish') {
            steps {
                echo '📦 Publishing application...'
                sh 'dotnet publish --no-build --configuration Release --output ./publish'
                archiveArtifacts artifacts: 'publish/**', fingerprint: true
            }
        }

        // Build Docker image from project Dockerfile.
        stage('Docker Build') {
            steps {
                echo '🐳 Building Docker image...'
                script {
                    docker.build("${DOCKER_IMAGE}:${DOCKER_TAG}")
                }
            }
        }

        // Push image to registry with build tag and latest.
        stage('Docker Push') {
            steps {
                echo '🐳 Pushing Docker image...'
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'docker-hub-credentials') {
                        def image = docker.image("${DOCKER_IMAGE}:${DOCKER_TAG}")
                        image.push()
                        image.push('latest')
                    }
                }
            }
        }

        // Deploy to staging. Replace with your deployment (kubectl, Helm, docker run, etc.).
        stage('Deploy') {
            steps {
                echo "🚀 Deploying to ${DEPLOY_ENV}..."
                sh """
                    echo "Deploying ${DOCKER_IMAGE}:${DOCKER_TAG} to ${DEPLOY_ENV}"
                    # Docker: docker run -d -p 8080:8080 ${DOCKER_IMAGE}:${DOCKER_TAG}
                    # Kubernetes: kubectl set image deployment/dotnet-app dotnet-app=${DOCKER_IMAGE}:${DOCKER_TAG}
                """
            }
        }
    }

    // Post-build: notify on success/failure, always clean workspace.
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
