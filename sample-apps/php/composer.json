{
    "name": "sample-php-app",
    "description": "Minimal PHP application for CI/CD pipeline demos",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.4",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit tests/",
        "lint": "phpcs src/",
        "analyze": "phpstan analyse src/"
    }
}